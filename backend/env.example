# ─────────────────────────── AI Workspace — backend .env ───────────────────────────
# Database
MONGO_URL="mongodb://localhost:27017"
DB_NAME="ai_workspace"
CORS_ORIGINS="*"

# development | production  (dev-login отключается автоматически в production)
ENVIRONMENT="development"

# ─────────────────────────── AI провайдер ───────────────────────────
# ВАРИАНТ A (рекомендуется, работает из коробки): Google Gemini — бесплатный тариф.
#   1. Открой https://aistudio.google.com/app/apikey
#   2. "Create API key" (карта и подписка НЕ нужны). Новый ключ начинается с "AQ."
#   3. Вставь сюда. Доступны модели: gemini-2.5-flash / gemini-2.5-flash-lite / gemini-2.5-pro
GEMINI_API_KEY="AQ.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ВАРИАНТ B (опционально): OmniRoute — self-hosted AI-шлюз с 90+ бесплатными провайдерами
#   (DeepSeek, Gemini free, Grok, Pollinations и т.д.). https://github.com/diegosouzapw/OmniRoute
#   Запуск:  npm install -g omniroute && omniroute   (дашборд: http://localhost:20128/dashboard)
#   В дашборде подключи бесплатные провайдеры (Pollinations — вообще без ключа), затем укажи:
# OMNIROUTE_BASE_URL="http://localhost:20128/v1"
# OMNIROUTE_API_KEY="omniroute-dashboard-key"
# OMNIROUTE_MODEL="auto"   # или pol/gpt-5, if/kimi-k2-thinking, deepseek/deepseek-chat и т.д.

# ─────────────────────────── Telegram Login Widget ───────────────────────────
# 1. Создай бота у @BotFather → получишь токен.
# 2. Выполни /setdomain и укажи домен фронтенда (напр. your-app.preview.emergentagent.com),
#    иначе виджет входа не отобразится. Токен НИКОГДА не кладём во фронтенд.
TELEGRAM_BOT_TOKEN="123456789:AA-your-bot-token"
TELEGRAM_BOT_USERNAME="YourBotUsername"

# ─────────────────────────── Сессии (JWT) ───────────────────────────
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS="168"

# ─────────────────────────── Тестовый вход (без Telegram) ───────────────────────────
# Работает только когда ENVIRONMENT != production. Позволяет войти по tg_id без виджета.
DEV_LOGIN_SECRET="dev-only-secret"

# ─────────────────────────── Публичный URL Mini App ───────────────────────────
# Нужен, чтобы бэкенд на старте вызвал setChatMenuButton и поставил кнопку "Открыть".
# На Railway задайте после первого деплоя фронта, затем Redeploy.
APP_URL="https://your-frontend.netlify.app"

